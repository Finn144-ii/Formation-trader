<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Formation Trader Rentable</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–navy: #0D1B2A;
–navy2: #1B2B3A;
–blue: #1A56DB;
–blue-light: #3B82F6;
–green: #16A34A;
–white: #FFFFFF;
–off: #F8FAFC;
–grey: #64748B;
–light: #E2E8F0;
–text: #1E293B;
}

html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, ‘Segoe UI’, sans-serif; color: var(–text); background: var(–white); }

nav {
background: var(–navy);
padding: 16px 24px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
z-index: 100;
}
.nav-logo { color: white; font-weight: 800; font-size: 17px; }
.nav-logo span { color: #93C5FD; }
.nav-cta {
background: var(–blue);
color: white;
padding: 9px 20px;
border-radius: 6px;
font-size: 13px;
font-weight: 600;
text-decoration: none;
}

.hero {
background: linear-gradient(160deg, var(–navy) 0%, var(–navy2) 100%);
color: white;
padding: 70px 24px 80px;
text-align: center;
}

.hero-tag {
display: inline-block;
background: rgba(59,130,246,0.15);
border: 1px solid rgba(59,130,246,0.3);
color: #93C5FD;
font-size: 12px;
font-weight: 600;
padding: 7px 16px;
border-radius: 20px;
margin-bottom: 28px;
}

.hero h1 {
font-size: clamp(32px, 7vw, 58px);
font-weight: 900;
line-height: 1.15;
margin-bottom: 20px;
max-width: 680px;
margin-left: auto;
margin-right: auto;
}

.hero h1 em { color: #93C5FD; font-style: normal; }

.hero-desc {
font-size: 16px;
color: #94A3B8;
max-width: 500px;
margin: 0 auto 36px;
line-height: 1.8;
}

.hero-desc strong { color: white; }

.btn-primary {
display: inline-block;
background: var(–blue);
color: white;
padding: 16px 40px;
border-radius: 8px;
font-size: 16px;
font-weight: 700;
text-decoration: none;
box-shadow: 0 4px 20px rgba(26,86,219,0.4);
}

.hero-price {
font-size: 14px;
color: #64748B;
margin-top: 14px;
}
.hero-price s { color: #475569; }
.hero-price strong { color: #4ADE80; font-size: 16px; }

.stats {
background: var(–off);
border-top: 1px solid var(–light);
border-bottom: 1px solid var(–light);
padding: 32px 24px;
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 24px;
max-width: 700px;
margin: 0 auto;
text-align: center;
}

@media(min-width: 600px) { .stats { grid-template-columns: repeat(4, 1fr); } }

.stat-num { font-size: 30px; font-weight: 900; color: var(–navy); line-height: 1; }
.stat-label { font-size: 12px; color: var(–grey); margin-top: 4px; font-weight: 500; }

.section { padding: 64px 24px; max-width: 800px; margin: 0 auto; }

.section-label {
display: inline-block;
background: #EFF6FF;
color: var(–blue);
font-size: 11px;
font-weight: 700;
letter-spacing: 2px;
text-transform: uppercase;
padding: 5px 12px;
border-radius: 4px;
margin-bottom: 14px;
}

.section h2 {
font-size: clamp(26px, 5vw, 40px);
font-weight: 900;
color: var(–navy);
margin-bottom: 12px;
line-height: 1.2;
}

.section-sub { font-size: 15px; color: var(–grey); line-height: 1.8; max-width: 560px; }

.audience-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 14px;
margin-top: 32px;
}

.audience-card {
padding: 18px;
border-radius: 10px;
border: 1px solid var(–light);
display: flex;
gap: 10px;
align-items: flex-start;
background: var(–off);
}

.audience-icon { font-size: 20px; flex-shrink: 0; }
.audience-text { font-size: 13px; font-weight: 600; color: var(–text); line-height: 1.5; }

.programme { background: var(–off); border-top: 1px solid var(–light); border-bottom: 1px solid var(–light); }

.prog-list { margin-top: 32px; display: flex; flex-direction: column; gap: 12px; }

.prog-item {
background: white;
border: 1px solid var(–light);
border-radius: 10px;
padding: 18px 20px;
display: flex;
gap: 14px;
align-items: flex-start;
}

.prog-num {
background: var(–navy);
color: white;
font-size: 12px;
font-weight: 800;
width: 30px; height: 30px;
border-radius: 8px;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}

.prog-title { font-size: 15px; font-weight: 700; color: var(–navy); margin-bottom: 4px; }
.prog-desc { font-size: 13px; color: var(–grey); line-height: 1.6; }

.testi-grid {
display: grid;
grid-template-columns: 1fr;
gap: 14px;
margin-top: 32px;
}

@media(min-width:580px) { .testi-grid { grid-template-columns: 1fr 1fr; } }

.testi-card {
background: var(–off);
border: 1px solid var(–light);
border-radius: 12px;
padding: 22px;
}

.testi-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.testi-avatar {
width: 40px; height: 40px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-size: 16px;
background: var(–navy);
color: white;
font-weight: 800;
flex-shrink: 0;
}
.testi-name { font-size: 14px; font-weight: 700; color: var(–navy); }
.testi-role { font-size: 12px; color: var(–grey); }
.testi-stars { color: #FBBF24; font-size: 13px; margin-bottom: 8px; }
.testi-text { font-size: 13px; color: #475569; line-height: 1.7; font-style: italic; }
.result-badge {
display: inline-block;
background: #DCFCE7;
color: var(–green);
font-size: 12px;
font-weight: 700;
padding: 4px 10px;
border-radius: 20px;
margin-top: 10px;
}

.garantie-box {
background: linear-gradient(135deg, #EFF6FF, #F0FDF4);
border: 1px solid #BFDBFE;
border-radius: 14px;
padding: 36px 24px;
text-align: center;
max-width: 760px;
margin: 0 auto 64px;
}

.garantie-box .icon { font-size: 44px; margin-bottom: 12px; }
.garantie-box h3 { font-size: 24px; font-weight: 900; color: var(–navy); margin-bottom: 10px; }
.garantie-box p { font-size: 14px; color: var(–grey); max-width: 440px; margin: 0 auto; line-height: 1.8; }

.offre-section {
background: var(–navy);
padding: 72px 24px;
text-align: center;
}

.offre-section h2 {
font-size: clamp(28px, 5vw, 48px);
font-weight: 900;
color: white;
margin-bottom: 8px;
}

.offre-section h2 em { color: #93C5FD; font-style: normal; }

.offre-card {
background: white;
border-radius: 16px;
padding: 36px 28px;
max-width: 440px;
margin: 32px auto 0;
text-align: left;
}

.offre-price-block { text-align: center; margin-bottom: 24px; }
.offre-price-old { font-size: 15px; color: var(–grey); text-decoration: line-through; }
.offre-price-new { font-size: 52px; font-weight: 900; color: var(–navy); line-height: 1; }
.offre-price-note { font-size: 13px; color: var(–green); font-weight: 600; margin-top: 4px; }

.offre-includes h4 { font-size: 12px; font-weight: 700; color: var(–grey); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }

.offre-item {
display: flex;
align-items: center;
gap: 10px;
padding: 8px 0;
border-bottom: 1px solid var(–light);
font-size: 14px;
font-weight: 500;
color: var(–text);
}

.offre-item:last-child { border-bottom: none; }
.check { color: var(–green); font-size: 16px; }

.btn-offre {
display: block;
background: var(–blue);
color: white;
text-align: center;
padding: 16px;
border-radius: 8px;
font-size: 16px;
font-weight: 700;
text-decoration: none;
margin-top: 24px;
box-shadow: 0 4px 20px rgba(26,86,219,0.3);
}

.offre-secure { text-align: center; font-size: 12px; color: var(–grey); margin-top: 10px; }

.faq-list { margin-top: 28px; display: flex; flex-direction: column; gap: 10px; }

.faq-item { border: 1px solid var(–light); border-radius: 10px; overflow: hidden; }

.faq-q {
padding: 16px 18px;
font-size: 14px;
font-weight: 600;
color: var(–navy);
cursor: pointer;
display: flex;
justify-content: space-between;
align-items: center;
background: white;
}

.faq-a {
padding: 0 18px;
font-size: 13px;
color: var(–grey);
line-height: 1.8;
max-height: 0;
overflow: hidden;
transition: max-height 0.3s ease, padding 0.3s;
background: var(–off);
}

.faq-item.open .faq-a { max-height: 200px; padding: 14px 18px; }
.faq-arrow { transition: transform 0.3s; font-size: 12px; color: var(–grey); }
.faq-item.open .faq-arrow { transform: rotate(180deg); }

footer {
background: var(–navy);
padding: 24px;
text-align: center;
font-size: 12px;
color: #475569;
}
footer a { color: #64748B; text-decoration: none; margin: 0 6px; }
</style>

</head>
<body>

